---
import skills from '../data/skills.json';
const categories = Object.entries(skills) as [string, string[]][];
---
<section id="skills" class="py-16">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="text-2xl font-semibold mb-8">Skills</h2>
    <div class="space-y-6">
      {categories.map(([category, items]) => (
        <div>
          <h3 class="text-sm font-medium text-text-secondary mb-3">{category}</h3>
          <div class="flex flex-wrap gap-2">
            {items.map((skill: string) => (
              <span class="px-3 py-1.5 bg-accent-light text-accent text-sm font-medium rounded-full">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
